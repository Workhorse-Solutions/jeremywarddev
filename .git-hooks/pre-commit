#!/usr/bin/env bash
# Abort if Gemfile.lock contains a local PATH entry for rails_foundry_cli.
# This happens when Gemfile uses `path: "rails_foundry_cli"` for local development.
# Revert to the git tag reference before committing.

set -euo pipefail

if grep -q "^PATH" Gemfile.lock 2>/dev/null && \
   grep -A5 "^PATH" Gemfile.lock | grep -q "rails.foundry.cli"; then
  echo ""
  echo "ERROR: Gemfile.lock contains a local PATH reference to rails_foundry_cli."
  echo "Revert Gemfile to the git tag before committing:"
  echo ""
  echo "  gem \"rails_foundry_cli\", git: \"https://github.com/Workhorse-Solutions/rails-foundry-cli.git\", tag: \"v0.1.0\""
  echo ""
  echo "Then run: bundle install"
  echo ""
  exit 1
fi
