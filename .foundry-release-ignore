# RailsFoundry Release Exclusion Manifest
# Paths listed here are stripped from the release snapshot before pushing
# to the rails_foundry release repository.
#
# Format: one path per line. Glob patterns are supported. Use # for comments.

# Gem source — consumers reference the gem via git: in their Gemfile
rails_foundry_cli/

# AI tooling (dev-only; recreated via `rails generate rails_foundry_cli:ai_tooling`)
.claude/

# Documentation content (dev-only; keep directory skeleton for work_prd workflow)
docs/prd/prd-*.md
docs/prd/complete/prd-*.md

# Dev-only AI docs (LESSONS and RELEASE are internal; STACK/WORKFLOWS/MCP ship to consumers)
docs/ai/LESSONS.md
docs/ai/RELEASE.md

# Release tooling itself (dev-only)
.foundry-release-ignore

# Dev-only git hooks (strips local PATH refs from Gemfile.lock before commits)
.git-hooks/

# Dev-only environment and marker files
.env
.env.local
.railsfoundry-dev

# Demo / landing page content (installed by the demo generator; not part of the base template)
app/components/landing/
app/views/public/pages/pricing.html.erb
db/seeds.demo.rb
test/components/landing/
