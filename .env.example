# ============================================================
# RailsFoundry — Per-app identity variables
# ============================================================
# IMPORTANT: Every app cloned from RailsFoundry MUST set a unique
# APP_IDENTIFIER to avoid collisions in Postgres database names,
# session cookies, Docker Compose project names, and Kamal service
# names when multiple apps run on the same machine or server.
#
# Rules:
#   • APP_IDENTIFIER  – snake_case, lowercase, no spaces
#                       Used for: DB names, session cookie key, deploy service
#   • APP_NAME        – Human-readable display name (spaces OK)
#
# Example for a different app:
#   APP_IDENTIFIER=workhorse_rental
#   APP_NAME=Workhorse Rental
# ============================================================

APP_NAME=RailsFoundry
APP_IDENTIFIER=railsfoundry

# ============================================================
# AI Tooling — RailsFoundry CLI gem (optional)
# ============================================================
# The rails_foundry_cli gem (AI skills, hooks, generators) lives
# in the :foundry_cli Bundler group. It installs automatically
# with `bundle install` if you have SSH access to the gem repo.
#
# To skip it (e.g. in CI without SSH):
#   bundle config set --local without foundry_cli

# ============================================================
# Rack::Attack — Rate limit thresholds (optional overrides)
# ============================================================
# Uncomment and adjust these to tune rate limits per environment.
# Defaults are shown as comments.
#
# POST /login — per IP (burst protection)
# RACK_ATTACK_LOGIN_LIMIT=5
# RACK_ATTACK_LOGIN_PERIOD=20
#
# POST /login — per email (credential stuffing protection)
# RACK_ATTACK_LOGIN_EMAIL_LIMIT=10
# RACK_ATTACK_LOGIN_EMAIL_PERIOD=900
#
# POST /signup — per IP
# RACK_ATTACK_SIGNUP_LIMIT=3
# RACK_ATTACK_SIGNUP_PERIOD=60
#
# POST /forgot-password — per IP
# RACK_ATTACK_FORGOT_PASSWORD_LIMIT=3
# RACK_ATTACK_FORGOT_PASSWORD_PERIOD=60
#
# POST /forgot-password — per email
# RACK_ATTACK_FORGOT_PASSWORD_EMAIL_LIMIT=5
# RACK_ATTACK_FORGOT_PASSWORD_EMAIL_PERIOD=3600
#
# POST /resend-verification and /email-verification/resend — per IP
# RACK_ATTACK_RESEND_VERIFICATION_LIMIT=3
# RACK_ATTACK_RESEND_VERIFICATION_PERIOD=60

# ============================================================
# Personal site — Email subscriber sync (optional)
# ============================================================
# ConvertKit integration
# CONVERTKIT_API_KEY=
# CONVERTKIT_FORM_ID=

# Mailchimp integration (alternative to ConvertKit)
# MAILCHIMP_API_KEY=
# MAILCHIMP_LIST_ID=

# Plausible analytics
# PLAUSIBLE_DOMAIN=
