// For format details, see https://containers.dev/implementors/json_reference/
{
  "name": "RailsFoundry",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  // Persist GitHub CLI credentials and Claude config across container rebuilds
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.config/gh,target=/home/vscode/.config/gh,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
  ],

  // Composable features — installed on top of the base image
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/rails/devcontainer/features/activestorage": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": { "moby": false },
    "ghcr.io/rails/devcontainer/features/postgres-client": {}
  },

  // Developer-tool env vars belong here, not in docker-compose
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "CAPYBARA_SERVER_PORT": "45678",
    "SELENIUM_HOST": "selenium"
  },

  "forwardPorts": [3000, 5432],

  "portsAttributes": {
    "3000": { "label": "Rails", "onAutoForward": "openBrowser" },
    "5432": { "label": "Postgres", "onAutoForward": "silent" }
  },
  "otherPortsAttributes": { "onAutoForward": "ignore" },

  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "GitHub.vscode-github-actions",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "anthropic.claude-code"
      ]
    }
  },

  "remoteUser": "vscode",

  "postCreateCommand": "mkdir -p ~/.ssh && ssh-keyscan github.com >> ~/.ssh/known_hosts 2>/dev/null && npm i -g @anthropic-ai/claude-code@latest && bin/setup --skip-server",
  "postStartCommand": "echo '\n✅ Dev container ready. Run bin/dev to start the Rails server.\n'"
}
