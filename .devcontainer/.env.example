# Copy this file to .devcontainer/.env (git-ignored) before opening the
# devcontainer. Docker Compose reads these variables and substitutes them into
# docker-compose.yml via ${APP_IDENTIFIER:-railsfoundry}.
#
# Each app cloned from RailsFoundry MUST use a unique APP_IDENTIFIER to avoid
# collisions in Postgres database names, session cookies, and Compose project
# names when multiple apps run on the same machine.
#
# Example for a different app:
#   APP_IDENTIFIER=workhorse_rental
#   APP_NAME=Workhorse Rental

APP_NAME=RailsFoundry
APP_IDENTIFIER=railsfoundry
