<%= render UI::ModalComponent.new(
  id: "turbo-confirm",
  title: "",
  size: :sm,
  open: false,
  close_label: cancel_label,
  title_data: { behavior: "title" }
) do |modal| %>
  <% modal.with_footer do %>
    <form method="dialog" class="flex gap-2">
      <button class="btn btn-ghost btn-sm" value=""><%= cancel_label %></button>
      <button class="btn btn-error btn-sm" value="confirm"><%= confirm_label %></button>
    </form>
  <% end %>
  <p class="mt-2 text-sm text-base-content/70" data-behavior="description"></p>
  <div class="mt-3 space-y-2">
    <p class="text-sm text-base-content/70" data-behavior="instructions"></p>
    <input type="text" class="input input-bordered input-sm w-full" autocomplete="off" data-behavior="confirm-text">
  </div>
<% end %>
