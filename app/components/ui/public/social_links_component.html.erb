<% if full? %>
  <ul class="space-y-2">
    <% links.each do |link| %>
      <li>
        <%= link_to link.url, target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center gap-2 link link-hover" do %>
          <%= icon_for(link.platform).html_safe %>
          <span><%= link.label %></span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="flex items-center gap-4">
    <% links.each do |link| %>
      <%= link_to link.url, target: "_blank", rel: "noopener noreferrer", class: "link link-hover", aria: { label: link.label } do %>
        <%= icon_for(link.platform).html_safe %>
      <% end %>
    <% end %>
  </div>
<% end %>
