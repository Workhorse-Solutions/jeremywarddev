<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
  <% if reversed %>
    <div class="<%= visual_wrapper_class %>"><%= visual_column %></div>
    <div><%= text_column %></div>
  <% else %>
    <div><%= text_column %></div>
    <div class="<%= visual_wrapper_class %>"><%= visual_column %></div>
  <% end %>
</div>
