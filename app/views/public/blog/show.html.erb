<section class="py-16">
  <div class="container mx-auto px-4 max-w-3xl">
    <article>
      <!-- Back link -->
      <div class="mb-8">
        <%= link_to "← Back to Blog", blog_path, class: "link link-hover text-base-content/60" %>
      </div>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex gap-2 mb-4">
          <% @post.tags.each do |tag| %>
            <span class="badge badge-outline"><%= tag %></span>
          <% end %>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4"><%= @post.title %></h1>
        <div class="flex items-center gap-4 text-base-content/60">
          <span><%= @post.formatted_date %></span>
          <span>·</span>
          <span><%= @post.reading_time %></span>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none
                  prose-headings:font-bold
                  prose-a:text-primary
                  prose-code:text-secondary
                  prose-pre:bg-base-200
                  prose-pre:border prose-pre:border-base-300">
        <%= @post.body %>
      </div>

      <!-- Post footer -->
      <div class="divider mt-16"></div>

      <div class="bg-base-200 p-8 rounded-lg text-center mt-8">
        <h3 class="text-xl font-bold mb-3">Enjoyed this post?</h3>
        <p class="text-base-content/70 mb-6">
          I write about building SaaS products solo with Rails. Get updates straight to your inbox.
        </p>
        <div id="email-form">
          <%= render "public/subscribers/form", subscriber: Subscriber.new %>
        </div>
      </div>
    </article>
  </div>
</section>
