<% content_for :title, "Blog" %>

<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="mb-12">
    <h1 class="text-4xl font-bold mb-4">Blog</h1>
    <p class="text-lg opacity-70">Thoughts on software, business, and building things.</p>
  </div>

  <% if @posts.empty? %>
    <div class="text-center py-16 opacity-50">
      <p class="text-lg">No posts yet. Check back soon.</p>
    </div>
  <% else %>
    <div class="space-y-8">
      <% @posts.each do |post| %>
        <article class="card bg-base-100 border border-base-300">
          <div class="card-body">
            <div class="flex items-center gap-2 text-sm opacity-60 mb-2">
              <time datetime="<%= post.published_at.iso8601 %>">
                <%= post.published_at.strftime("%B %-d, %Y") %>
              </time>
            </div>
            <h2 class="card-title text-2xl">
              <%= link_to post.title, blog_post_path(post.slug), class: "hover:text-primary" %>
            </h2>
            <% if post.metadata["excerpt"].present? %>
              <p class="opacity-70"><%= post.metadata["excerpt"] %></p>
            <% end %>
            <div class="card-actions mt-4">
              <%= link_to "Read more →", blog_post_path(post.slug), class: "link link-primary" %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  <% end %>
</div>
