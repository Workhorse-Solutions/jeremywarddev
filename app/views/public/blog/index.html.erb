<section class="py-16">
  <div class="container mx-auto px-4 max-w-3xl">
    <div class="flex justify-between items-center mb-10">
      <div>
        <h1 class="text-4xl font-bold">Blog</h1>
        <p class="text-base-content/60 mt-2">Build-in-public updates, Rails insights, and lessons from the trenches.</p>
      </div>
      <a href="<%= blog_feed_path(format: :rss) %>" class="btn btn-ghost btn-sm" title="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </div>

    <% if @posts.any? %>
      <div class="space-y-8">
        <% @posts.each do |post| %>
          <%= link_to blog_post_path(post.slug), class: "block group" do %>
            <article class="card bg-base-200 hover:bg-base-300 transition-colors">
              <div class="card-body">
                <div class="flex gap-2 mb-1">
                  <% post.tags.each do |tag| %>
                    <span class="badge badge-outline badge-sm"><%= tag %></span>
                  <% end %>
                </div>
                <h2 class="card-title text-xl group-hover:text-primary transition-colors"><%= post.title %></h2>
                <p class="text-base-content/60"><%= post.excerpt %></p>
                <div class="flex items-center gap-4 text-sm text-base-content/40 mt-2">
                  <span><%= post.formatted_date %></span>
                  <span>·</span>
                  <span><%= post.reading_time %></span>
                </div>
              </div>
            </article>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <p class="text-base-content/40 text-lg">Posts coming soon. Stay tuned.</p>
      </div>
    <% end %>
  </div>
</section>
