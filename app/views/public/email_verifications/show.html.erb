<% content_for :title, t("public.email_verifications.show.title") %>

<%= render UI::SectionComponent.new(
  outer_class: "min-h-screen flex items-center justify-center px-4",
  inner_class: "flex items-center justify-center w-full") do %>
  <%= render UI::CardComponent.new(class_name: "w-full max-w-sm shadow-xl") do %>
    <h1 class="card-title text-2xl font-bold justify-center mb-2">
      <%= t("public.email_verifications.show.title") %>
    </h1>

    <p class="text-sm text-base-content/70 text-center mb-4">
      <%= t("public.email_verifications.show.instructions") %>
    </p>

    <%= form_with url: resend_verification_path, method: :post, class: "space-y-4" do |f| %>
      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :email,
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :email,
            type: :email,
            input_html: { autocomplete: "email", autofocus: true, required: true }
          ) %>
        <% end %>
      <% end %>

      <div class="card-actions">
        <%= f.submit t("public.email_verifications.resend.submit"),
          class: "btn btn-primary w-full" %>
      </div>
    <% end %>

    <div class="text-sm text-center mt-4">
      <%= link_to t("public.email_verifications.show.back_to_login"), login_path,
        class: "link link-primary" %>
    </div>
  <% end %>
<% end %>
