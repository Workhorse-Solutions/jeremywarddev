<!-- Hero Section -->
<section class="hero min-h-[70vh] bg-base-200">
  <div class="hero-content text-center py-20">
    <div class="max-w-3xl">
      <h1 class="text-5xl md:text-6xl font-bold leading-tight">
        Solo Rails developer.<br>
        <span class="text-primary">Building real SaaS products.</span>
      </h1>
      <p class="py-6 text-xl text-base-content/70 max-w-2xl mx-auto">
        20 years shipping code. Multiple products in production. Sharing everything I learn about building software businesses as a solo founder.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <%= link_to "See What I'm Building", projects_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "Read the Blog", blog_path, class: "btn btn-outline btn-lg" %>
      </div>
    </div>
  </div>
</section>

<!-- Email Signup -->
<section class="py-16 bg-base-100">
  <div class="container mx-auto px-4 max-w-2xl text-center">
    <h2 class="text-3xl font-bold mb-4">Build-in-public updates</h2>
    <p class="text-base-content/70 mb-8">
      I share what's working, what's not, and what I'm learning. No spam, no fluff — just real lessons from building SaaS products solo.
    </p>
    <div id="email-form">
      <%= render "public/subscribers/form", subscriber: Subscriber.new %>
    </div>
  </div>
</section>

<!-- Recent Posts -->
<% if @recent_posts.any? %>
<section class="py-16 bg-base-200">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="flex justify-between items-center mb-10">
      <h2 class="text-3xl font-bold">Recent Posts</h2>
      <%= link_to "View All →", blog_path, class: "link link-primary font-medium" %>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      <% @recent_posts.each do |post| %>
        <%= link_to blog_post_path(post.slug), class: "card bg-base-100 shadow-sm hover:shadow-md transition-shadow" do %>
          <div class="card-body">
            <div class="flex gap-2 mb-2">
              <% post.tags.first(2).each do |tag| %>
                <span class="badge badge-outline badge-sm"><%= tag %></span>
              <% end %>
            </div>
            <h3 class="card-title text-lg"><%= post.title %></h3>
            <p class="text-base-content/60 text-sm line-clamp-2"><%= post.excerpt %></p>
            <div class="text-xs text-base-content/40 mt-auto pt-4">
              <%= post.formatted_date %> · <%= post.reading_time %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Featured Projects -->
<% if @projects.any? %>
<section class="py-16 bg-base-100">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="flex justify-between items-center mb-10">
      <h2 class="text-3xl font-bold">What I'm Building</h2>
      <%= link_to "All Projects →", projects_path, class: "link link-primary font-medium" %>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      <% @projects.each do |project| %>
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <div class="flex items-center gap-2">
              <h3 class="card-title text-lg"><%= project.name %></h3>
              <span class="badge badge-sm <%= project.status_badge %>"><%= project.status_label %></span>
            </div>
            <p class="text-base-content/70 text-sm"><%= project.tagline %></p>
            <div class="flex flex-wrap gap-1 mt-2">
              <% project.stack.first(3).each do |tech| %>
                <span class="badge badge-ghost badge-xs"><%= tech %></span>
              <% end %>
            </div>
            <% if project.url.present? && project.url != "#" %>
              <div class="card-actions justify-end mt-4">
                <%= link_to "Learn More →", project.url, target: "_blank", rel: "noopener", class: "link link-primary text-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<!-- Stack/Credibility -->
<section class="py-16 bg-base-200">
  <div class="container mx-auto px-4 max-w-3xl text-center">
    <h2 class="text-3xl font-bold mb-8">The Stack</h2>
    <div class="flex flex-wrap justify-center gap-3">
      <% ["Ruby on Rails 8", "Hotwire / Turbo", "Tailwind CSS", "PostgreSQL", "Kamal", "Solid Queue", "DaisyUI", "ActiveStorage"].each do |tech| %>
        <span class="badge badge-lg badge-outline"><%= tech %></span>
      <% end %>
    </div>
    <p class="mt-8 text-base-content/60">
      Every product in the portfolio runs this stack. Battle-tested across multiple production apps.
    </p>
  </div>
</section>
