<% content_for :title, t(".title") %>

<%= render UI::Public::HeroComponent.new(
  title: t(".hero_title"),
  size: :compact
) %>

<div data-controller="scroll-reveal">
  <%# Intro %>
  <section class="py-20 md:py-28">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <div class="lg:col-span-7">
          <div class="fade-in-up">
            <div class="accent-line mb-8"></div>
            <p class="text-xl md:text-2xl leading-relaxed text-base-content/90 mb-6">
              <%= t(".bio.intro") %>
            </p>
            <p class="text-base text-base-content/70 leading-relaxed mb-6">
              <%= t(".bio.mission") %>
            </p>
          </div>

          <div class="fade-in-up stagger-2 space-y-6 text-base text-base-content/70 leading-relaxed">
            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-primary mb-2" style="font-family: 'JetBrains Mono', monospace;"><%= t(".bio.difference_heading") %></p>
              <p><%= t(".bio.difference") %></p>
            </div>

            <p><%= t(".bio.build_in_public") %></p>

            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-primary mb-2" style="font-family: 'JetBrains Mono', monospace;"><%= t(".bio.background_heading") %></p>
              <p><%= t(".bio.background") %></p>
            </div>

            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-primary mb-2" style="font-family: 'JetBrains Mono', monospace;"><%= t(".bio.philosophy_heading") %></p>
              <p><%= t(".bio.philosophy") %></p>
            </div>

            <p><%= t(".bio.sustainable") %></p>

            <div>
              <p class="text-xs uppercase tracking-[0.3em] text-primary mb-2" style="font-family: 'JetBrains Mono', monospace;"><%= t(".bio.content_heading") %></p>
              <p><%= t(".bio.content") %></p>
            </div>
          </div>
        </div>

        <%# Sidebar info %>
        <div class="lg:col-span-5">
          <div class="fade-in-up stagger-3 sticky top-24">
            <div class="border border-base-content/10 p-6 mb-6" style="border-radius: 0.375rem;">
              <p class="text-xs uppercase tracking-[0.3em] text-primary mb-4" style="font-family: 'JetBrains Mono', monospace;">Details</p>
              <div class="space-y-4 text-sm">
                <div class="flex justify-between border-b border-base-content/5 pb-3">
                  <span class="text-base-content/50">Location</span>
                  <span>Idaho Falls, ID</span>
                </div>
                <div class="flex justify-between border-b border-base-content/5 pb-3">
                  <span class="text-base-content/50">Experience</span>
                  <span>20+ years</span>
                </div>
                <div class="flex justify-between border-b border-base-content/5 pb-3">
                  <span class="text-base-content/50">Stack</span>
                  <span>Rails 8 + AI</span>
                </div>
                <div class="flex justify-between border-b border-base-content/5 pb-3">
                  <span class="text-base-content/50">Focus</span>
                  <span>Micro SaaS</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-base-content/50">Mode</span>
                  <span class="text-primary">Building</span>
                </div>
              </div>
            </div>

            <div class="border border-base-content/10 p-6" style="border-radius: 0.375rem;">
              <p class="text-xs uppercase tracking-[0.3em] text-primary mb-4" style="font-family: 'JetBrains Mono', monospace;"><%= t(".social.heading") %></p>
              <%= render UI::Public::SocialLinksComponent.new(
                links: [
                  UI::Public::SocialLinksComponent::Link.new(platform: :github, label: "Workhorse-Solutions", url: "https://github.com/Workhorse-Solutions"),
                  UI::Public::SocialLinksComponent::Link.new(platform: :x, label: "@jrmyward", url: "https://x.com/jrmyward"),
                  UI::Public::SocialLinksComponent::Link.new(platform: :x, label: "@jeremywarddev", url: "https://x.com/jeremywarddev"),
                  UI::Public::SocialLinksComponent::Link.new(platform: :linkedin, label: "in/jrmyward", url: "https://linkedin.com/in/jrmyward"),
                  UI::Public::SocialLinksComponent::Link.new(platform: :youtube, label: "@jeremywarddev", url: "https://youtube.com/@jeremywarddev"),
                  UI::Public::SocialLinksComponent::Link.new(platform: :youtube, label: "@jeremywardoutdoors", url: "https://youtube.com/@jeremywardoutdoors")
                ],
                variant: :full
              ) %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
