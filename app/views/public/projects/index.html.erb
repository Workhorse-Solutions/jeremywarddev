<section class="py-16">
  <div class="container mx-auto px-4 max-w-5xl">
    <div class="mb-10">
      <h1 class="text-4xl font-bold">Projects</h1>
      <p class="text-base-content/60 mt-2">Real software in production. Not side projects — businesses.</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <% @projects.each do |project| %>
        <div class="card bg-base-200 shadow-sm hover:shadow-md transition-shadow">
          <div class="card-body">
            <div class="flex items-center gap-3 mb-2">
              <h2 class="card-title text-xl"><%= project.name %></h2>
              <span class="badge badge-sm <%= project.status_badge %>"><%= project.status_label %></span>
            </div>
            <p class="text-primary font-medium text-sm mb-2"><%= project.tagline %></p>
            <p class="text-base-content/70"><%= project.description %></p>
            <div class="flex flex-wrap gap-1 mt-4">
              <% project.stack.each do |tech| %>
                <span class="badge badge-ghost badge-sm"><%= tech %></span>
              <% end %>
            </div>
            <div class="card-actions justify-end mt-4">
              <% if project.url.present? && project.url != "#" %>
                <a href="<%= project.url %>" target="_blank" rel="noopener" class="btn btn-primary btn-sm">Visit →</a>
              <% end %>
              <% if project.github_url.present? %>
                <a href="<%= project.github_url %>" target="_blank" rel="noopener" class="btn btn-outline btn-sm">GitHub</a>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
