<% content_for :title, t(".title") %>

<div class="space-y-6 max-w-2xl">
  <%= render UI::CardComponent.new do %>
    <h1 class="card-title text-2xl font-bold mb-6"><%= t(".heading") %></h1>

    <%= form_with model: @form, url: settings_account_path, scope: :settings_account, method: :patch, class: "space-y-4" do |f| %>
      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :name,
        label: t(".name_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :name,
            input_html: { autocomplete: "organization" }
          ) %>
        <% end %>
      <% end %>

      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :slug,
        label: t(".slug_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :slug
          ) %>
        <% end %>
      <% end %>

      <div class="card-actions">
        <%= f.submit t(".submit"), class: "btn btn-primary" %>
      </div>
    <% end %>
  <% end %>

  <%= render UI::CardComponent.new do %>
    <h2 class="card-title text-lg font-semibold mb-4"><%= t(".billing.heading") %></h2>
    <dl class="space-y-3" data-testid="billing-section">
      <div>
        <dt class="text-sm text-base-content/70"><%= t(".billing.status") %></dt>
        <dd class="font-medium"><%= Current.account.billing_status %></dd>
      </div>
      <div>
        <dt class="text-sm text-base-content/70"><%= t(".billing.trial_ends_at") %></dt>
        <dd class="font-medium">
          <%= Current.account.trial_ends_at&.strftime("%B %-d, %Y") || t(".billing.not_applicable") %>
        </dd>
      </div>
    </dl>
  <% end %>
</div>
