<% content_for :title, t(".title") %>

<div class="space-y-6 max-w-2xl">
  <%= render UI::CardComponent.new do %>
    <h2 class="card-title text-2xl font-bold mb-2"><%= t(".personal_details.heading") %></h2>

    <%= form_with model: @personal_details_form, url: settings_profile_path, scope: :settings_profile, method: :patch, class: "space-y-4" do |f| %>
      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :first_name,
        label: t(".personal_details.first_name_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :first_name,
            input_html: { autocomplete: "given-name" }
          ) %>
        <% end %>
      <% end %>

      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :last_name,
        label: t(".personal_details.last_name_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :last_name,
            input_html: { autocomplete: "family-name" }
          ) %>
        <% end %>
      <% end %>

      <div class="card-actions">
        <%= f.submit t(".personal_details.submit"), class: "btn btn-primary" %>
      </div>
    <% end %>
  <% end %>

  <%= render UI::CardComponent.new do %>
    <h2 class="card-title text-2xl font-bold mb-2"><%= t(".security.heading") %></h2>

    <div class="flex items-center justify-between py-2 border-b border-base-300 mb-4" data-testid="email-row">
      <div>
        <p class="text-neutral text-base font-semibold pb-1"><%= t(".security.email_label") %></p>
        <p class="text-base"><%= Current.user.email %></p>
      </div>
      <%= link_to t(".security.change_email"), edit_email_settings_path, class: "link link-primary text-sm", data: { turbo_frame: "modal" } %>
    </div>

    <%= form_with model: @password_form, url: settings_profile_password_path, scope: :settings_password, method: :patch, class: "space-y-4" do |f| %>
      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :current_password,
        label: t(".security.current_password_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :current_password,
            type: :password,
            input_html: { autocomplete: "current-password" }
          ) %>
        <% end %>
      <% end %>

      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :password,
        label: t(".security.new_password_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :password,
            type: :password,
            input_html: { autocomplete: "new-password" }
          ) %>
        <% end %>
      <% end %>

      <%= render Form::ControlComponent.new(
        form: f,
        attribute: :password_confirmation,
        label: t(".security.password_confirmation_label")
      ) do |field| %>
        <% field.with_input do %>
          <%= render Form::InputComponent.new(
            form: f,
            attribute: :password_confirmation,
            type: :password,
            input_html: { autocomplete: "new-password" }
          ) %>
        <% end %>
      <% end %>

      <div class="card-actions">
        <%= f.submit t(".security.submit"), class: "btn btn-primary" %>
      </div>
    <% end %>
  <% end %>
</div>
