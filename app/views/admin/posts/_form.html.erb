<%= form_with model: [:admin, post], class: "space-y-6" do |f| %>
  <% if post.errors.any? %>
    <div class="alert alert-error">
      <ul class="list-disc list-inside">
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control">
    <%= f.label :title, class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full", placeholder: "Post title" %>
  </div>

  <div class="form-control">
    <%= f.label :slug, class: "label" %>
    <%= f.text_field :slug, class: "input input-bordered w-full font-mono", placeholder: "auto-generated from title" %>
    <div class="label"><span class="label-text-alt opacity-60">Lowercase letters, numbers, and hyphens only. Leave blank to auto-generate.</span></div>
  </div>

  <div class="grid grid-cols-2 gap-6">
    <div class="form-control">
      <%= f.label :status, class: "label" %>
      <%= f.select :status, Post::STATUSES.map { |s| [s.capitalize, s] }, {}, class: "select select-bordered w-full" %>
    </div>

    <div class="form-control">
      <%= f.label :published_at, class: "label" %>
      <%= f.datetime_local_field :published_at, class: "input input-bordered w-full", value: post.published_at&.strftime("%Y-%m-%dT%H:%M") %>
    </div>
  </div>

  <div class="form-control">
    <%= f.label :body, "Body (Markdown)", class: "label" %>
    <%= f.text_area :body, class: "textarea textarea-bordered w-full font-mono", rows: 20, placeholder: "Write your post in Markdown..." %>
  </div>

  <div class="flex gap-4">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_posts_path, class: "btn btn-ghost" %>
  </div>
<% end %>
