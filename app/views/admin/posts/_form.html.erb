<%= form_with model: [:admin, post], class: "space-y-4 max-w-2xl" do |f| %>
  <% if post.errors.any? %>
    <div class="alert alert-error">
      <ul>
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-control">
    <%= f.label :title, class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full", autofocus: true %>
  </div>

  <div class="form-control">
    <%= f.label :slug, class: "label" %>
    <%= f.text_field :slug, class: "input input-bordered w-full",
      placeholder: "auto-generated from title if blank" %>
  </div>

  <div class="form-control">
    <%= f.label :body, "Body (Markdown)", class: "label" %>
    <%= f.text_area :body, class: "textarea textarea-bordered w-full h-64", rows: 20 %>
  </div>

  <div class="form-control">
    <%= f.label :status, class: "label" %>
    <%= f.select :status, Post::STATUSES.map { |s| [s.capitalize, s] },
      {}, class: "select select-bordered w-full" %>
  </div>

  <div class="form-control">
    <%= f.label :published_at, class: "label" %>
    <%= f.datetime_local_field :published_at, class: "input input-bordered w-full" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", admin_posts_path, class: "btn btn-ghost" %>
  </div>
<% end %>
