<% content_for :title, @post.title %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold"><%= @post.title %></h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_admin_post_path(@post), class: "btn btn-sm btn-ghost" %>
    <%= link_to "Back", admin_posts_path, class: "btn btn-sm btn-ghost" %>
  </div>
</div>

<div class="card bg-base-100 shadow-sm">
  <div class="card-body">
    <div class="flex gap-4 mb-4 text-sm text-base-content/60">
      <span>
        Status:
        <% case @post.status %>
        <% when "published" %>
          <span class="badge badge-success badge-sm">Published</span>
        <% when "scheduled" %>
          <span class="badge badge-info badge-sm">Scheduled</span>
        <% when "draft" %>
          <span class="badge badge-warning badge-sm">Draft</span>
        <% end %>
      </span>
      <span>Slug: <code class="text-xs"><%= @post.slug %></code></span>
      <% if @post.published_at %>
        <span>Published: <%= l(@post.published_at, format: :short) %></span>
      <% end %>
    </div>

    <div class="divider"></div>

    <div class="prose max-w-none">
      <%= raw @post.body_html %>
    </div>
  </div>
</div>
