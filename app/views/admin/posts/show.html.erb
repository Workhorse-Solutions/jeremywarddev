<% content_for :title, @post.title %>

<div class="p-6 max-w-4xl">
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-4">
      <%= link_to "← Posts", admin_posts_path, class: "btn btn-ghost btn-sm" %>
      <h1 class="text-2xl font-bold"><%= @post.title %></h1>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_admin_post_path(@post), class: "btn btn-primary btn-sm" %>
      <%= button_to "Delete", admin_post_path(@post), method: :delete, class: "btn btn-error btn-sm btn-outline", data: { turbo_confirm: "Delete this post?" } %>
    </div>
  </div>

  <div class="card bg-base-100 border border-base-300 mb-6">
    <div class="card-body">
      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="font-medium opacity-60">Slug</dt>
          <dd class="font-mono"><%= @post.slug %></dd>
        </div>
        <div>
          <dt class="font-medium opacity-60">Status</dt>
          <dd>
            <span class="badge <%= @post.published? ? 'badge-success' : @post.scheduled? ? 'badge-warning' : 'badge-neutral' %>">
              <%= @post.status %>
            </span>
          </dd>
        </div>
        <% if @post.published_at %>
          <div>
            <dt class="font-medium opacity-60">Published At</dt>
            <dd><%= @post.published_at.strftime("%B %-d, %Y at %H:%M UTC") %></dd>
          </div>
        <% end %>
        <% if @post.live? %>
          <div>
            <dt class="font-medium opacity-60">Live URL</dt>
            <dd><%= link_to blog_post_path(@post.slug), blog_post_path(@post.slug), class: "link link-primary" %></dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>

  <div class="prose max-w-none">
    <%= raw @post.body_html %>
  </div>
</div>
