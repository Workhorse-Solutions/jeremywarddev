<% content_for(:title) { @content.title } %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold"><%= @content.title %></h1>
      <div class="mt-1 flex items-center gap-2">
        <span class="badge badge-ghost"><%= @content.agent_name %></span>
        <span class="badge badge-outline"><%= @content.content_type.humanize %></span>
        <span class="badge <%= case @content.status
          when 'pending_approval' then 'badge-warning'
          when 'approved' then 'badge-success'
          when 'published' then 'badge-primary'
          when 'scheduled' then 'badge-info'
          when 'rejected' then 'badge-error'
          else 'badge-ghost'
        end %>"><%= @content.status.humanize %></span>
      </div>
    </div>

    <%= link_to "← Back", admin_content_index_path, class: "btn btn-ghost btn-sm" %>
  </div>

  <%# Metadata %>
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-sm uppercase tracking-wide text-base-content/60">Details</h2>
      <div class="grid grid-cols-2 gap-4 text-sm md:grid-cols-4">
        <div>
          <span class="text-base-content/60">Created</span>
          <p class="font-medium"><%= @content.created_at.strftime("%b %d, %Y %l:%M %p") %></p>
        </div>
        <% if @content.approved_at %>
          <div>
            <span class="text-base-content/60">Approved</span>
            <p class="font-medium"><%= @content.approved_at.strftime("%b %d, %Y %l:%M %p") %></p>
          </div>
        <% end %>
        <% if @content.scheduled_for %>
          <div>
            <span class="text-base-content/60">Scheduled For</span>
            <p class="font-medium"><%= @content.scheduled_for.strftime("%b %d, %Y %l:%M %p") %></p>
          </div>
        <% end %>
        <% if @content.published_at %>
          <div>
            <span class="text-base-content/60">Published</span>
            <p class="font-medium"><%= @content.published_at.strftime("%b %d, %Y %l:%M %p") %></p>
          </div>
        <% end %>
        <% if @content.metadata.present? %>
          <% @content.metadata.each do |key, value| %>
            <div>
              <span class="text-base-content/60"><%= key.humanize %></span>
              <p class="font-medium"><%= value %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Content Preview %>
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-sm uppercase tracking-wide text-base-content/60">Content Preview</h2>
      <div class="prose max-w-none">
        <%= simple_format(@content.body) %>
      </div>
    </div>
  </div>

  <%# Actions %>
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-sm uppercase tracking-wide text-base-content/60">Actions</h2>
      <div class="flex flex-wrap gap-2">
        <% if @content.pending_approval? %>
          <%= button_to "Approve", approve_admin_content_path(@content), method: :post, class: "btn btn-success" %>
          <%= link_to "Edit", edit_admin_content_path(@content), class: "btn btn-ghost" %>
          <div class="flex items-center gap-2">
            <%= form_with url: reject_admin_content_path(@content), method: :post, class: "flex items-center gap-2" do |f| %>
              <%= f.text_field :note, placeholder: "Rejection note (optional)", class: "input input-bordered input-sm w-64" %>
              <%= f.submit "Reject", class: "btn btn-error btn-sm" %>
            <% end %>
          </div>
        <% elsif @content.approved? || @content.scheduled? %>
          <%= link_to "Edit", edit_admin_content_path(@content), class: "btn btn-ghost" %>
        <% end %>

        <%= button_to "Delete", admin_content_path(@content), method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete this content?" },
          class: "btn btn-outline btn-error btn-sm" %>
      </div>
    </div>
  </div>
</div>
