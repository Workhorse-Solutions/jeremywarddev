<% content_for(:title) { "Agent Content" } %>

<div class="space-y-8">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Agent Content</h1>
  </div>

  <%# Pending Approval %>
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-warning">
        <span class="size-5"><%= heroicon "clock", variant: :mini %></span>
        Pending Approval (<%= @pending.size %>)
      </h2>

      <% if @pending.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>Agent</th>
                <th>Type</th>
                <th>Title</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @pending.each do |content| %>
                <tr>
                  <td><span class="badge badge-ghost"><%= content.agent_name %></span></td>
                  <td><span class="badge badge-outline"><%= content.content_type.humanize %></span></td>
                  <td><%= link_to content.title, admin_content_path(content), class: "link link-primary" %></td>
                  <td class="text-sm text-base-content/60"><%= time_ago_in_words(content.created_at) %> ago</td>
                  <td class="flex gap-1">
                    <%= link_to "View", admin_content_path(content), class: "btn btn-ghost btn-xs" %>
                    <%= button_to "Approve", approve_admin_content_path(content), method: :post, class: "btn btn-success btn-xs" %>
                    <%= button_to "Reject", reject_admin_content_path(content), method: :post, class: "btn btn-error btn-xs" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-base-content/60">No content pending approval.</p>
      <% end %>
    </div>
  </div>

  <%# Scheduled %>
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-info">
        <span class="size-5"><%= heroicon "calendar", variant: :mini %></span>
        Scheduled (<%= @scheduled.size %>)
      </h2>

      <% if @scheduled.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>Agent</th>
                <th>Type</th>
                <th>Title</th>
                <th>Scheduled For</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @scheduled.each do |content| %>
                <tr>
                  <td><span class="badge badge-ghost"><%= content.agent_name %></span></td>
                  <td><span class="badge badge-outline"><%= content.content_type.humanize %></span></td>
                  <td><%= link_to content.title, admin_content_path(content), class: "link link-primary" %></td>
                  <td class="text-sm"><%= content.scheduled_for&.strftime("%b %d, %Y %l:%M %p") %></td>
                  <td>
                    <%= link_to "View", admin_content_path(content), class: "btn btn-ghost btn-xs" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-base-content/60">No scheduled content.</p>
      <% end %>
    </div>
  </div>

  <%# Recently Approved %>
  <div class="card bg-base-100 shadow">
    <div class="card-body">
      <h2 class="card-title text-success">
        <span class="size-5"><%= heroicon "check-circle", variant: :mini %></span>
        Recently Approved
      </h2>

      <% if @approved.any? %>
        <div class="overflow-x-auto">
          <table class="table">
            <thead>
              <tr>
                <th>Agent</th>
                <th>Type</th>
                <th>Title</th>
                <th>Approved</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @approved.each do |content| %>
                <tr>
                  <td><span class="badge badge-ghost"><%= content.agent_name %></span></td>
                  <td><span class="badge badge-outline"><%= content.content_type.humanize %></span></td>
                  <td><%= link_to content.title, admin_content_path(content), class: "link link-primary" %></td>
                  <td class="text-sm text-base-content/60"><%= content.approved_at&.strftime("%b %d, %Y") %></td>
                  <td>
                    <%= link_to "View", admin_content_path(content), class: "btn btn-ghost btn-xs" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-base-content/60">No approved content yet.</p>
      <% end %>
    </div>
  </div>
</div>
