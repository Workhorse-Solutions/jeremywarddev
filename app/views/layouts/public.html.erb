<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("public.layout.app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="jeremyward.dev">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="grain-overlay"></div>

    <%= render UI::Public::HeaderComponent.new(
      brand: { label: t("public.layout.app_name"), href: root_path },
      nav_items: [
        { label: t("public.layout.nav.home"), href: root_path },
        { label: t("public.layout.nav.portfolio"), href: portfolio_path },
        { label: t("public.layout.nav.about"), href: about_path },
        { label: t("public.layout.nav.blog"), href: blog_path }
      ],
      ctas: [
        { label: t("public.layout.header.sign_in"), href: login_path, css_class: "btn btn-ghost btn-sm border border-base-content/20 hover:border-primary hover:text-primary transition-colors" }
      ],
      open_drawer_aria_label: t("public.layout.header.open_sidebar_aria"),
      close_drawer_aria_label: t("public.layout.header.close_sidebar_aria")
    ) %>

    <main class="flex-1">
      <%= turbo_frame_tag "flash" do %>
        <%= render UI::ToastsComponent.new(flash: flash) %>
      <% end %>
      <%= yield %>
    </main>

    <%= render UI::Public::FooterComponent.new(
      copyright: t("public.layout.footer.copyright"),
      social_links: [
        UI::Public::SocialLinksComponent::Link.new(platform: :github, label: "Workhorse-Solutions", url: "https://github.com/Workhorse-Solutions"),
        UI::Public::SocialLinksComponent::Link.new(platform: :x, label: "@jrmyward", url: "https://x.com/jrmyward"),
        UI::Public::SocialLinksComponent::Link.new(platform: :linkedin, label: "in/jrmyward", url: "https://linkedin.com/in/jrmyward"),
        UI::Public::SocialLinksComponent::Link.new(platform: :youtube, label: "@jeremywarddev", url: "https://youtube.com/@jeremywarddev")
      ]
    ) %>
  </body>
</html>
