<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="author" content="Jeremy Ward">
    <%= display_meta_tags site: "Jeremy Ward", separator: "—", reverse: true %>
    <link rel="alternate" type="application/rss+xml" title="Jeremy Ward Dev Blog" href="<%= blog_feed_url(format: :rss) %>">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :tailwind, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= render "public/shared/analytics" %>
  </head>

  <body class="min-h-screen flex flex-col bg-base-100 text-base-content">
    <%= render "public/shared/navbar" %>

    <% if notice %>
      <div class="toast toast-top toast-end z-50">
        <div class="alert alert-success">
          <span><%= notice %></span>
        </div>
      </div>
    <% end %>

    <% if alert %>
      <div class="toast toast-top toast-end z-50">
        <div class="alert alert-error">
          <span><%= alert %></span>
        </div>
      </div>
    <% end %>

    <main class="flex-1">
      <%= yield %>
    </main>

    <%= render "public/shared/footer" %>
  </body>
</html>
